# ========================================\n# CELEBRA V4 - Environment Variables\n# ========================================\n\n# ========================================\n# DATABASE\n# ========================================\nDATABASE_URL=mysql://user:password@localhost:3306/celebra_prod\nDATABASE_POOL_SIZE=10\nDATABASE_CONNECTION_TIMEOUT=5000\n\n# ========================================\n# AWS S3 (File Storage)\n# ========================================\nAWS_ACCESS_KEY_ID=your_access_key_id\nAWS_SECRET_ACCESS_KEY=your_secret_access_key\nAWS_S3_BUCKET=celebra-prod\nAWS_REGION=us-east-1\nAWS_S3_URL=https://celebra-prod.s3.amazonaws.com\n\n# ========================================\n# FIREBASE (Push Notifications)\n# ========================================\nFIREBASE_PROJECT_ID=your_project_id\nFIREBASE_PRIVATE_KEY=your_private_key\nFIREBASE_CLIENT_EMAIL=your_client_email\nFIREBASE_DATABASE_URL=https://your-project.firebaseio.com\n\n# ========================================\n# OAUTH PROVIDERS\n# ========================================\n# Google OAuth\nGOOGLE_CLIENT_ID=your_google_client_id\nGOOGLE_CLIENT_SECRET=your_google_client_secret\nGOOGLE_CALLBACK_URL=https://api.celebra.app/api/oauth/google/callback\n\n# Facebook OAuth\nFACEBOOK_APP_ID=your_facebook_app_id\nFACEBOOK_APP_SECRET=your_facebook_app_secret\nFACEBOOK_CALLBACK_URL=https://api.celebra.app/api/oauth/facebook/callback\n\n# Manus OAuth\nMANUS_CLIENT_ID=your_manus_client_id\nMANUS_CLIENT_SECRET=your_manus_client_secret\nMANUS_CALLBACK_URL=https://api.celebra.app/api/oauth/manus/callback\n\n# ========================================\n# PAYMENT PROCESSING (Stripe)\n# ========================================\nSTRIPE_PUBLIC_KEY=pk_live_your_public_key\nSTRIPE_SECRET_KEY=sk_live_your_secret_key\nSTRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret\n\n# ========================================\n# MUSIC PLATFORM INTEGRATIONS\n# ========================================\n# Spotify\nSPOTIFY_CLIENT_ID=your_spotify_client_id\nSPOTIFY_CLIENT_SECRET=your_spotify_client_secret\nSPOTIFY_REDIRECT_URI=https://celebra.app/api/spotify/callback\n\n# YouTube\nYOUTUBE_API_KEY=your_youtube_api_key\nYOUTUBE_CLIENT_ID=your_youtube_client_id\nYOUTUBE_CLIENT_SECRET=your_youtube_client_secret\n\n# TikTok\nTIKTOK_CLIENT_ID=your_tiktok_client_id\nTIKTOK_CLIENT_SECRET=your_tiktok_client_secret\nTIKTOK_API_KEY=your_tiktok_api_key\n\n# Apple Music\nAPPLE_MUSIC_KEY=your_apple_music_key\nAPPLE_MUSIC_TEAM_ID=your_apple_music_team_id\n\n# ========================================\n# MONITORING & LOGGING\n# ========================================\n# Sentry (Error Tracking)\nSENTRY_DSN=https://your_key@sentry.io/your_project_id\nSENTRY_ENVIRONMENT=production\nSENTRY_TRACE_SAMPLE_RATE=0.1\n\n# DataDog (APM)\nDATADOG_API_KEY=your_datadog_api_key\nDATADOG_SITE=datadoghq.com\n\n# CloudWatch (AWS Logs)\nCLOUDWATCH_LOG_GROUP=/celebra/production\nCLOUDWATCH_LOG_STREAM=api-server\n\n# ========================================\n# EMAIL SERVICE\n# ========================================\nSMTP_HOST=smtp.gmail.com\nSMTP_PORT=587\nSMTP_USER=your_email@gmail.com\nSMTP_PASSWORD=your_app_password\nSMTP_FROM=noreply@celebra.app\nSMTP_FROM_NAME=CELEBRA\n\n# ========================================\n# JWT & SECURITY\n# ========================================\nJWT_SECRET=your_super_secret_jwt_key_change_this_in_production\nJWT_EXPIRY=7d\nJWT_REFRESH_EXPIRY=30d\nSESSION_SECRET=your_session_secret_key\nSESSION_TIMEOUT=86400000 # 24 hours in milliseconds\n\n# ========================================\n# DOMAIN & URLs\n# ========================================\nDOMAIN=celebra.app\nAPI_URL=https://api.celebra.app\nFRONTEND_URL=https://celebra.app\nWEBSOCKET_URL=wss://api.celebra.app\n\n# ========================================\n# REDIS (Caching & Sessions)\n# ========================================\nREDIS_URL=redis://localhost:6379\nREDIS_PASSWORD=your_redis_password\nREDIS_DB=0\n\n# ========================================\n# RATE LIMITING\n# ========================================\nRATE_LIMIT_WINDOW_MS=900000 # 15 minutes\nRATE_LIMIT_MAX_REQUESTS=100\nRATE_LIMIT_AUTH_MAX=5\nRATE_LIMIT_UPLOAD_MAX=10\n\n# ========================================\n# FILE UPLOAD\n# ========================================\nMAX_FILE_SIZE=104857600 # 100MB in bytes\nMAX_AUDIO_FILE_SIZE=104857600 # 100MB\nALLOWED_AUDIO_TYPES=mp3,wav,ogg,m4a,flac\nALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp\n\n# ========================================\n# ANALYTICS\n# ========================================\n# Google Analytics\nGOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X\n\n# Mixpanel\nMIXPANEL_TOKEN=your_mixpanel_token\n\n# Amplitude\nAMPLITUDE_API_KEY=your_amplitude_api_key\n\n# ========================================\n# SUPPORT & COMMUNICATION\n# ========================================\n# Intercom\nINTERCOM_APP_ID=your_intercom_app_id\n\n# Zendesk\nZENDESK_DOMAIN=your_subdomain.zendesk.com\nZENDESK_EMAIL=your_email@zendesk.com\nZENDESK_API_TOKEN=your_zendesk_api_token\n\n# ========================================\n# ENVIRONMENT\n# ========================================\nNODE_ENV=production\nLOG_LEVEL=info\nDEBUG=false\n\n# ========================================\n# FEATURE FLAGS\n# ========================================\nFEATURE_SPOTIFY_INTEGRATION=true\nFEATURE_YOUTUBE_INTEGRATION=true\nFEATURE_TIKTOK_INTEGRATION=true\nFEATURE_APPLE_MUSIC_INTEGRATION=false # Coming soon\nFEATURE_LIVE_STREAMING=true\nFEATURE_PUSH_NOTIFICATIONS=true\nFEATURE_MONETIZATION=true\nFEATURE_OFFLINE_MODE=true\n\n# ========================================\n# MAINTENANCE\n# ========================================\nMAINTENANCE_MODE=false\nMAINTENANCE_MESSAGE=We are currently performing scheduled maintenance. Please try again later.\n\n# ========================================\n# BACKUP & DISASTER RECOVERY\n# ========================================\nBACKUP_ENABLED=true\nBACKUP_FREQUENCY=daily # daily, weekly, monthly\nBACKUP_RETENTION_DAYS=30\nBACKUP_STORAGE_PATH=s3://celebra-backups/\n\n# ========================================\n# GDPR & PRIVACY\n# ========================================\nGDPR_ENABLED=true\nCOOKIE_CONSENT_REQUIRED=true\nDATA_RETENTION_DAYS=365\nALLOW_DATA_EXPORT=true\nALLOW_DATA_DELETION=true\n"
